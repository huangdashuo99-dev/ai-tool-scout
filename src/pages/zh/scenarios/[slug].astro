---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { type Lang, t } from '../../../utils/i18n';

const lang: Lang = 'zh';

export async function getStaticPaths() {
  const scenarios = await getCollection('scenarios');
  return scenarios.map((s) => ({
    params: { slug: s.slug },
    props: { scenario: s },
  }));
}

const { scenario } = Astro.props;
const { data: scenData } = scenario;

const allTools = await getCollection('tools');
const scenarioTools = scenData.tools
  .map((slug) => allTools.find((t) => t.slug === slug))
  .filter(Boolean)
  .sort((a, b) => (b?.data.rating ?? 0) - (a?.data.rating ?? 0));
---

<BaseLayout
  lang={lang}
  title={scenData.title}
  description={scenData.description}
  canonicalUrl={`https://aitoolscout.com/${lang}/scenarios/${scenario.slug}`}
  currentPath={`/${lang}/scenarios/${scenario.slug}`}
>
  <Breadcrumb lang={lang} crumbs={[
    { label: t(lang, 'breadcrumb.home'), href: '/' },
    { label: t(lang, 'breadcrumb.scenarios') },
    { label: scenData.title },
  ]} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-900">{scenData.icon} {scenData.title}</h1>
    <p class="mt-2 text-lg text-gray-600">{scenData.description}</p>

    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {scenarioTools.map((tool) => tool && <ToolCard tool={tool} lang={lang} />)}
    </div>
  </section>
</BaseLayout>
