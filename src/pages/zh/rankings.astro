---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { type Lang, t } from '../../utils/i18n';

const lang: Lang = 'zh';

const allTools = await getCollection('tools');
const categories = await getCollection('categories');
const sortedCategories = categories.sort((a, b) => a.data.order - b.data.order);

const rankedTools = [...allTools].sort(
  (a, b) => b.data.rating - a.data.rating || b.data.dateAdded.getTime() - a.data.dateAdded.getTime()
);
---

<BaseLayout
  lang={lang}
  title={t(lang, 'rankings.pageTitle')}
  description={t(lang, 'rankings.pageSubtitle')}
  canonicalUrl={`https://aitoolscout.com/${lang}/rankings`}
  currentPath={`/${lang}/rankings`}
>
  <Breadcrumb lang={lang} crumbs={[
    { label: t(lang, 'breadcrumb.home'), href: '/' },
    { label: t(lang, 'breadcrumb.rankings') },
  ]} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-900">🏆 {t(lang, 'rankings.pageTitle')}</h1>
    <p class="mt-2 text-gray-600">{t(lang, 'rankings.pageSubtitle')}</p>

    <div class="mt-6 flex flex-wrap gap-2 mb-8">
      <a href={`/${lang}/rankings`} class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium">{t(lang, 'rankings.all')}</a>
      {sortedCategories.map((cat) => (
        <a href={`/${lang}/categories/${cat.slug}`} class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-medium transition-colors">
          {cat.data.icon} {(lang === 'zh' && cat.data.titleZh) ? cat.data.titleZh : cat.data.title}
        </a>
      ))}
    </div>

    <div class="space-y-3">
      {rankedTools.map((tool, i) => (
        <div class="flex items-center gap-4">
          <span class="w-8 h-8 flex items-center justify-center bg-primary-100 text-primary-700 font-bold rounded-lg text-sm">{i + 1}</span>
          <div class="flex-1">
            <ToolCard tool={tool} lang={lang} showCategory={true} />
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
