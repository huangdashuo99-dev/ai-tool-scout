---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { type Lang, t, langPathPrefix } from '../../../utils/i18n';

const lang: Lang = 'zh';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const { data: catData } = category;

const title = (lang === 'zh' && catData.titleZh) ? catData.titleZh : catData.title;
const description = (lang === 'zh' && catData.descriptionZh) ? catData.descriptionZh : catData.description;

const allTools = await getCollection('tools');
const categoryTools = allTools
  .filter((t) => t.data.category === category.slug)
  .sort((a, b) => (b.data.rating ?? 0) - (a.data.rating ?? 0) || b.data.dateAdded.getTime() - a.data.dateAdded.getTime());
---

<BaseLayout
  lang={lang}
  title={`${catData.icon} ${title} AI Tools`}
  description={description}
  canonicalUrl={`https://aitoolscout.com${langPathPrefix(lang)}categories/${category.slug}`}
  currentPath={`${langPathPrefix(lang)}categories/${category.slug}`}
>
  <Breadcrumb lang={lang} crumbs={[
    { label: t(lang, 'breadcrumb.home'), href: '/' },
    { label: t(lang, 'breadcrumb.allTools'), href: '/tools' },
    { label: title },
  ]} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-900">{catData.icon} {title}</h1>
    <p class="mt-2 text-gray-600">{description}</p>
    <p class="mt-1 text-sm text-gray-400">{categoryTools.length} {t(lang, 'common.tools')}</p>

    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryTools.map((tool) => (
        <ToolCard tool={tool} lang={lang} />
      ))}
    </div>
  </section>
</BaseLayout>
