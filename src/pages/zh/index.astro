---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import ScenarioCard from '../../components/ScenarioCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';
import { type Lang, t } from '../../utils/i18n';

const lang: Lang = 'zh';
const allTools = await getCollection('tools');
const categories = await getCollection('categories');
const scenarios = await getCollection('scenarios');

const sortedCategories = categories.sort((a, b) => a.data.order - b.data.order);

const topTools = [...allTools]
  .sort((a, b) => b.data.rating - a.data.rating || b.data.dateAdded.getTime() - a.data.dateAdded.getTime())
  .slice(0, 10);

const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const newTools = allTools
  .filter((t) => t.data.isNew || t.data.dateAdded >= thirtyDaysAgo)
  .sort((a, b) => b.data.dateAdded.getTime() - a.data.dateAdded.getTime())
  .slice(0, 6);

const hotTags = ['写作', '图像生成', '编程', '免费', '聊天机器人', '视频'];
---

<BaseLayout
  lang={lang}
  title={`${t(lang, 'home.heroTitle1')} ${t(lang, 'home.heroTitle2')}`}
  description={t(lang, 'home.heroSubtitle')}
  canonicalUrl={`https://aitoolscout.com/${lang}/`}
  currentPath={`/${lang}/`}
>
  <section class="bg-gradient-to-br from-primary-50 to-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900">
        {t(lang, 'home.heroTitle1')} <span class="text-primary-600">{t(lang, 'home.heroTitle2')}</span>
      </h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        {t(lang, 'home.heroSubtitle')}
      </p>
      <div id="search" class="mt-8 max-w-xl mx-auto"></div>
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        {hotTags.map((tag) => (
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-sm text-gray-600 hover:border-primary-300 hover:text-primary-600 cursor-pointer transition-colors">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900">🏆 {t(lang, 'home.topTools')}</h2>
      <a href={`/${lang}/rankings`} class="text-primary-600 hover:text-primary-700 font-medium text-sm">{t(lang, 'home.viewAllRankings')}</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {topTools.map((tool, i) => (
        <div class="relative">
          <span class="absolute -top-2 -left-2 z-10 w-7 h-7 flex items-center justify-center bg-primary-600 text-white text-xs font-bold rounded-full">{i + 1}</span>
          <ToolCard tool={tool} lang={lang} />
        </div>
      ))}
    </div>
  </section>

  <AdSlot position="home-after-rankings" />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">🎯 {t(lang, 'home.whatDoYouWant')}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
      {scenarios.map((scenario) => (
        <ScenarioCard scenario={scenario} lang={lang} />
      ))}
    </div>
  </section>

  {newTools.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">🆕 {t(lang, 'home.newThisWeek')}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {newTools.map((tool) => (
          <ToolCard tool={tool} lang={lang} showCategory={true} />
        ))}
      </div>
    </section>
  )}

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">📂 {t(lang, 'home.browseByCategory')}</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {sortedCategories.map((cat) => (
        <CategoryCard category={cat} lang={lang} />
      ))}
    </div>
  </section>
</BaseLayout>
