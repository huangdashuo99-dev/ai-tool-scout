---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import { type Lang } from '../../utils/i18n';

const lang: Lang = 'en';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => {
    // Split body at horizontal rule to separate EN and ZH content
    const parts = tool.body?.split(/\n---\n/) || [''];
    const enBody = parts[0] || '';
    const zhBody = parts.length > 1 ? parts[1] : enBody;
    return {
      params: { slug: tool.slug },
      props: { tool, enBodyHtml: marked.parse(enBody) as string, zhBodyHtml: marked.parse(zhBody) as string },
    };
  });
}

const { tool, enBodyHtml, zhBodyHtml } = Astro.props;
const bodyHtml = lang === 'zh' ? zhBodyHtml : enBodyHtml;
---

<ToolLayout tool={tool} lang={lang} bodyHtml={bodyHtml} />
