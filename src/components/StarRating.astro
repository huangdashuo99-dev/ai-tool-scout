---
interface Props {
  rating?: number | null;
  size?: 'sm' | 'md' | 'lg';
}

const { rating, size = 'md' } = Astro.props;

if (!rating) return null;
---

<div class="flex items-center gap-1" aria-label={`Rating: ${rating} out of 5`}>
  <span class="ml-1 text-sm text-gray-600">{rating}</span>
</div>
