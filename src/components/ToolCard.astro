---
import StarRating from './StarRating.astro';
import type { CollectionEntry } from 'astro:content';
import { type Lang, t } from '../utils/i18n';

interface Props {
  tool: CollectionEntry<'tools'>;
  lang: Lang;
  showCategory?: boolean;
}

const { tool, lang, showCategory = false } = Astro.props;
const { data } = tool;

const pricingColors: Record<string, string> = {
  free: 'bg-green-100 text-green-700',
  freemium: 'bg-blue-100 text-blue-700',
  paid: 'bg-orange-100 text-orange-700',
};
---

<a href={`/${lang}/tools/${tool.slug}`} class="block group p-5 border border-gray-200 rounded-xl hover:border-primary-300 hover:shadow-md transition-all">
  <div class="flex items-start gap-4">
    <img src={data.logo} alt={`${data.title} logo`} class="w-12 h-12 rounded-lg flex-shrink-0" />
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors truncate">{data.title}</h3>
        {data.isNew && <span class="px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700 rounded-full">{t(lang, 'tools.new')}</span>}
      </div>
      <p class="mt-1 text-sm text-gray-500 line-clamp-2">{data.description}</p>
      <div class="mt-2 flex items-center gap-3">
        <StarRating rating={data.rating} size="sm" />
        <span class={`px-2 py-0.5 text-xs font-medium rounded-full ${pricingColors[data.pricing]}`}>
          {t(lang, `pricing.${data.pricing}`)}
        </span>
      </div>
      {showCategory && (
        <span class="mt-2 inline-block text-xs text-gray-400">{data.category}</span>
      )}
    </div>
  </div>
</a>
