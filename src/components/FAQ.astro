---
import { type Lang, t } from '../utils/i18n';

interface Props {
  items: Array<{ question: string; answer: string }>;
  lang?: Lang;
}

const { items, lang } = Astro.props;
---

<section class="mt-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-6">{lang ? t(lang, 'toolDetail.faq') : 'Frequently Asked Questions'}</h2>
  <div class="space-y-4">
    {items.map((item) => (
      <details class="group border border-gray-200 rounded-xl">
        <summary class="flex items-center justify-between p-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
          {item.question}
          <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-4 pb-4 text-gray-600">
          {item.answer}
        </div>
      </details>
    ))}
  </div>
</section>
