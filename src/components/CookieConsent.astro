---
import { type Lang, t, langPathPrefix } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div id="cookie-consent" class="fixed bottom-0 left-0 right-0 bg-gray-900 text-white p-4 z-50 hidden">
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm">
      {t(lang, 'cookie.message')}
      <a href={`${langPathPrefix(lang)}privacy`} class="underline hover:text-primary-300">{t(lang, 'cookie.privacyPolicy')}</a>.
    </p>
    <div class="flex gap-3">
      <button id="cookie-accept" class="px-4 py-2 bg-primary-600 hover:bg-primary-700 rounded-lg text-sm font-medium transition-colors">
        {t(lang, 'cookie.accept')}
      </button>
      <button id="cookie-decline" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 rounded-lg text-sm font-medium transition-colors">
        {t(lang, 'cookie.decline')}
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    try {
      var consent = localStorage.getItem('cookie-consent');
      var banner = document.getElementById('cookie-consent');
      if (!consent && banner) {
        banner.classList.remove('hidden');
      }
      document.getElementById('cookie-accept')?.addEventListener('click', function() {
        try { localStorage.setItem('cookie-consent', 'accepted'); } catch(e) {}
        banner?.classList.add('hidden');
      });
      document.getElementById('cookie-decline')?.addEventListener('click', function() {
        try { localStorage.setItem('cookie-consent', 'declined'); } catch(e) {}
        banner?.classList.add('hidden');
      });
    } catch(e) {
      // localStorage unavailable (e.g. Safari private browsing) — banner stays hidden
    }
  })();
</script>
