---
import { type Lang, langPathPrefix } from '../utils/i18n';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
  lang: Lang;
}

const { crumbs, lang } = Astro.props;

function prefixHref(href: string): string {
  if (href === '/') return langPathPrefix(lang);
  return `${langPathPrefix(lang)}${href.slice(1)}`;
}
---

<nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
  <ol class="flex items-center gap-2 text-sm text-gray-500" itemscope itemtype="https://schema.org/BreadcrumbList">
    {crumbs.map((crumb, i) => (
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="flex items-center gap-2">
        {i > 0 && <span class="text-gray-400">/</span>}
        {crumb.href ? (
          <a itemprop="item" href={prefixHref(crumb.href)} class="hover:text-primary-600 transition-colors">
            <span itemprop="name">{crumb.label}</span>
          </a>
        ) : (
          <span itemprop="name" class="text-gray-900">{crumb.label}</span>
        )}
        <meta itemprop="position" content={String(i + 1)} />
      </li>
    ))}
  </ol>
</nav>
