---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQ from '../components/FAQ.astro';
import StarRating from '../components/StarRating.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { type Lang, t } from '../utils/i18n';

interface Props {
  tool: CollectionEntry<'tools'>;
  lang: Lang;
  bodyHtml?: string;
}

const { tool, lang, bodyHtml } = Astro.props;
const { data } = tool;

// Select language-appropriate fields
const title = lang === 'zh' && data.titleZh ? data.titleZh : data.title;
const description = lang === 'zh' && data.descriptionZh ? data.descriptionZh : data.description;
const faqItems = lang === 'zh' && data.faqZh?.length ? data.faqZh : data.faq;

const allTools = await getCollection('tools');
const alternativeTools = data.alternatives
  .map((slug) => allTools.find((t) => t.slug === slug))
  .filter(Boolean) as CollectionEntry<'tools'>[];

const canonicalUrl = `https://aitoolscout.com/${lang}/tools/${tool.slug}`;

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
});

const ratingSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  description: description,
  applicationCategory: 'BusinessApplication',
  offers: {
    '@type': 'Offer',
    price: data.priceFrom.replace(/[^0-9.]/g, '') || '0',
    priceCurrency: 'USD',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: data.rating,
    bestRating: 5,
    ratingCount: 1,
  },
});
---

<BaseLayout
  lang={lang}
  title={`${title} Review`}
  description={description}
  canonicalUrl={canonicalUrl}
  currentPath={`/${lang}/tools/${tool.slug}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={faqSchema} />
    <script type="application/ld+json" set:html={ratingSchema} />
  </Fragment>

  <Breadcrumb lang={lang} crumbs={[
    { label: t(lang, 'breadcrumb.home'), href: '/' },
    { label: t(lang, 'nav.allTools'), href: '/tools' },
    { label: title },
  ]} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-start gap-6 mb-8">
      <img src={data.logo} alt={`${title} logo`} class="w-20 h-20 rounded-xl" />
      <div class="flex-1">
        <h1 class="text-3xl font-bold text-gray-900">{title}</h1>
        <p class="mt-2 text-lg text-gray-600">{description}</p>
        <div class="mt-3 flex items-center gap-4">
          <StarRating rating={data.rating} size="md" />
          <span class="px-3 py-1 rounded-full text-sm font-medium bg-primary-100 text-primary-700">{t(lang, `pricing.${data.pricing}`)}</span>
          <span class="text-sm text-gray-500">{t(lang, 'toolDetail.from')} {data.priceFrom}</span>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <a
        href={data.affiliateUrl}
        rel="nofollow sponsored"
        target="_blank"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-colors"
      >
        {t(lang, 'toolDetail.visit')} {title} →
      </a>
      <span class="ml-3 text-xs text-gray-400">{t(lang, 'toolDetail.sponsoredLink')}</span>
    </div>

    <div class="prose prose-lg max-w-none mb-8">
      {bodyHtml ? <Fragment set:html={bodyHtml} /> : <slot />}
    </div>

    <AdSlot position="tool-detail-mid" />

    {faqItems.length > 0 && <FAQ items={faqItems} lang={lang} />}

    {alternativeTools.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">{t(lang, 'toolDetail.alternatives')} {title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {alternativeTools.map((alt) => (
            <a href={`/${lang}/tools/${alt.slug}`} class="block p-4 border border-gray-200 rounded-xl hover:border-primary-300 hover:shadow-sm transition-all">
              <div class="flex items-center gap-3">
                <img src={alt.data.logo} alt={`${alt.data.title} logo`} class="w-10 h-10 rounded-lg" />
                <div>
                  <h3 class="font-semibold text-gray-900">{alt.data.title}</h3>
                  <StarRating rating={alt.data.rating} size="sm" />
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
